APP_NAME=PaqSuite-IA-PedidosWeb
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# SQL Server (ERP compartido): program_name en SSMS = DB_APP_NAME; lecturas sin bloqueo
# DB_CONNECTION=sqlsrv
# DB_APP_NAME=PedidosWeb
# DB_ISOLATION_LEVEL=READ UNCOMMITTED

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- PaqSuite MONO (PedidosWeb) ---
FRONTEND_URL=http://localhost:3010
TENANT_HEADER_NAME=X-Paq-Cliente
TENANT_ALLOWED_CLIENTS=desarrollo,demo
TENANT_DEFAULT_CLIENT=desarrollo

SEED_MVP_PASSWORD=ChangeMeInLocalEnv
SEED_MVP_SYNC_COMMERCIAL=false
PAQSUITE_MONO_EMPRESA_ID=8
# Solo true en base dev dedicada. Nunca en Ankas_del_sur / ERP compartido.
ALLOW_PEDIDOSWEB_DESTRUCTIVE_BOOTSTRAP=false
ADMIN_SECURITY_UI_ENABLED=false

# --- Chat Asistente IA — API keys LLM (solo dev local; no commitear valores reales) ---
# En producción cada usuario configura BYOK en Preferencias. Placeholders para copiar a .env local.
CHAT_ASSISTANT_LLM_OPENAI_API_KEY=
CHAT_ASSISTANT_LLM_ANTHROPIC_API_KEY=
CHAT_ASSISTANT_LLM_GOOGLE_GEMINI_API_KEY=
CHAT_ASSISTANT_LLM_AZURE_OPENAI_API_KEY=
CHAT_ASSISTANT_LLM_OPENROUTER_API_KEY=
CHAT_ASSISTANT_LLM_GROQ_API_KEY=
CHAT_ASSISTANT_LLM_MISTRAL_API_KEY=
CHAT_ASSISTANT_LLM_OLLAMA_API_KEY=
CHAT_ASSISTANT_LLM_TIMEOUT_SECONDS=60

SANCTUM_STATEFUL_DOMAINS=localhost:3010
SESSION_DOMAIN=localhost

# --- L5-Swagger (OpenAPI) ---
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8000
